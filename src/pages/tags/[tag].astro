---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('en');
  
  const allTags = new Set<string>();
  posts.forEach(post => post.data.tags?.forEach(tag => allTags.add(tag)));
  
  return Array.from(allTags).map(tag => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const posts = await getCollection('en');
const filteredPosts = posts
  .filter(post => post.data.tags?.includes(tag!))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={`CryptoGladi Blog. Tag: ${tag}`} description={`Posts tagged with ${tag}`}>
  <div class="tag-header">
    <a href="/tags" class="back-link">← All tags</a>
    <h2 class="page-title">#{tag}</h2>
    <p class="count">Found {filteredPosts.length} posts</p>
  </div>
  
  {filteredPosts.length > 0 ? (
    <ul class="post-list">
      {filteredPosts.map(post => (
        <li>
          <a href={`/blog/${post.id}`}>
            <strong>{post.data.title}</strong>
          </a>
          {post.data.description && <p>{post.data.description}</p>}
          <small>{post.data.date.toLocaleDateString('en-US')}</small>
        </li>
      ))}
    </ul>
  ) : (
    <p class="no-posts">No posts found with this tag.</p>
  )}
</BaseLayout>

<style>
  .tag-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .back-link { display: inline-block; color: var(--nord8); text-decoration: none; margin-bottom: 1rem; font-weight: 500; }
  .back-link:hover { color: var(--accent); text-decoration: underline; }
  .page-title { color: var(--text); margin: 0.5rem 0; font-size: 2rem; }
  .count { color: var(--text-muted); margin: 0; }
  ul.post-list { list-style: none; padding: 0; margin: 0; }
  li { margin: 1.25rem 0; padding: 1.25rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; transition: transform 0.2s, border-color 0.2s; }
  li:hover { transform: translateY(-2px); border-color: var(--accent); }
  li a { text-decoration: none; color: var(--accent); font-size: 1.2rem; display: block; margin-bottom: 0.5rem; }
  li a:hover { color: var(--accent-hover); text-decoration: underline; }
  li p { margin: 0.25rem 0 0.5rem; color: var(--text-muted); line-height: 1.5; }
  li small { color: var(--nord8); font-weight: 500; font-size: 0.85rem; }
  .no-posts { color: var(--text-muted); text-align: center; padding: 3rem; background: var(--surface); border-radius: 8px; border: 1px dashed var(--border); }
</style>