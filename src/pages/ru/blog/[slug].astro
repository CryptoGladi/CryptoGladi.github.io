---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';

const getReadingTime = (content: string): string => {
  const words = content.trim().split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 200))} мин.`;
};

export async function getStaticPaths() {
  const ruPosts = await getCollection('ru');
  const enPosts = await getCollection('en');

  return ruPosts.map(post => ({
    params: { slug: post.id },
    props: {
      post,
      locale: 'ru',
      hasTranslation: enPosts.some(e => e.id === post.id),
    },
  }));
}

const { post, hasTranslation } = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body);
---
<PostLayout 
  title={post.data.title} 
  date={post.data.date} 
  description={post.data.description}
  tags={post.data.tags || []}
  readingTime={readingTime}
  locale="ru"
  translationLink={hasTranslation ? `/blog/${post.id}` : null}
  translationLabel={hasTranslation ? "Also available in English" : null}
>
  <Content />
</PostLayout>