---
interface Props { title: string; description?: string }
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
  </head>
  <body>
    <header class="container">
      <nav>
          <a href="/">🏠 Main</a> | 
          <a href="/blog">📝 Blog</a> | 
          <a href="/tags">🏷️ Tags</a> |
          <a href="/rss.xml" target="_blank" rel="noopener">📡 RSS</a>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="container">
      <p>© {new Date().getFullYear()} CryptoGladi. Algorithm + Science + Rust 🦀</p>
    </footer>
  </body>
</html>

<style>
  :root {
    /* Nord Palette */
    --nord0: #2E3440; --nord1: #3B4252; --nord2: #434C5E; --nord3: #4C566A;
    --nord4: #D8DEE9; --nord5: #E5E9F0; --nord6: #ECEFF4;
    --nord7: #8FBCBB; --nord8: #88C0D0; --nord9: #81A1C1; --nord10: #5E81AC;
    --nord11: #BF616A; --nord12: #D08770; --nord13: #EBCB8B; --nord14: #A3BE8C; --nord15: #B48EAD;

    /* Theme mapping */
    --bg: var(--nord0);
    --surface: var(--nord1);
    --surface-hover: var(--nord2);
    --text: var(--nord6);
    --text-muted: var(--nord4);
    --accent: var(--nord8);
    --accent-hover: var(--nord9);
    --border: var(--nord3);
    --code-bg: var(--nord1);

    color-scheme: dark;
  }

  * { box-sizing: border-box; }
  :global(body) {
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.6;
    margin: 0;
    background: var(--bg);
    color: var(--text);
    transition: background 0.3s, color 0.3s;
  }

  .container { max-width: 74ch; margin: 0 auto; padding: 2rem 1.5rem; }

  nav a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: background 0.2s;
  }
  nav a:hover { background: var(--surface-hover); color: var(--text); }

  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding-top: 1.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  /* Фикс KaTeX для тёмной темы */
  .katex { color: var(--text) !important; }
  .katex .mord.text, .katex .mord.mathit { color: var(--text) !important; }
</style>