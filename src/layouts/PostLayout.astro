---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags: string[];
  readingTime: string;
  locale: 'en' | 'ru';
  translationLink?: string | null;
  translationLabel?: string | null;
}

const { title, date, description, tags = [], readingTime, locale, translationLink, translationLabel } = Astro.props;
const formatted = date.toLocaleDateString(locale === 'en' ? 'en-US' : 'ru-RU', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      {translationLink && translationLabel && (
        <a href={translationLink} class="translation-banner">
          🌍 {translationLabel}
        </a>
      )}
      
      <div class="meta-line">
        <time datetime={date.toISOString()}>{formatted}</time>
        <span class="separator">•</span>
        <span class="reading-time">📖 {readingTime}</span>
      </div>
      <h1>{title}</h1>
      {description && <p class="lead">{description}</p>}
      
      {tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .translation-banner {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--nord1);
    border: 1px solid var(--nord8);
    color: var(--nord8);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 1rem;
    transition: all 0.2s;
  }
  .translation-banner:hover {
    background: var(--nord10);
    color: var(--nord6);
    border-color: var(--nord9);
    transform: translateY(-1px);
  }

  .post-header { margin: 2rem 0 1.5rem; }
  .meta-line { display: flex; align-items: center; gap: 0.5rem; color: var(--nord8); font-weight: 500; font-size: 0.85rem; margin-bottom: 0.75rem; }
  .separator { color: var(--nord4); font-size: 1.2rem; line-height: 1; }
  .reading-time { display: inline-flex; align-items: center; gap: 0.25rem; }
  .post-header h1 { margin: 0.5rem 0; font-size: 2rem; line-height: 1.2; color: var(--text); }
  .lead { color: var(--text-muted); margin-top: 0.5rem; font-size: 1.1rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
  .tag { display: inline-block; padding: 0.25rem 0.75rem; background: var(--surface); border: 1px solid var(--border); border-radius: 999px; color: var(--nord9); font-size: 0.85rem; font-weight: 500; text-decoration: none; transition: all 0.2s; }
  .tag:hover { background: var(--nord10); border-color: var(--nord9); color: var(--nord6); transform: translateY(-1px); }

  .post-content :global(h2), .post-content :global(h3), .post-content :global(h4) { color: var(--text); margin-top: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
  .post-content :global(p) { margin: 1.25rem 0; }
  .post-content :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .post-content :global(a:hover) { color: var(--accent-hover); }
  .post-content :global(blockquote) { border-left: 4px solid var(--nord7); margin: 1.5rem 0; padding: 1rem 1.25rem; background: var(--surface); border-radius: 0 6px 6px 0; color: var(--text-muted); }
  .post-content :global(pre) { background: var(--code-bg); padding: 1rem; border-radius: 8px; overflow-x: auto; border: 1px solid var(--border); }
  .post-content :global(code) { font-family: 'Fira Code', 'JetBrains Mono', monospace; font-size: 0.9em; }
  .post-content :global(p code) { background: var(--surface); padding: 0.2em 0.4em; border-radius: 4px; color: var(--nord13); }
  .post-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; border: 1px solid var(--border); }
</style>